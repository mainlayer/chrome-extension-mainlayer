{
  "manifest_version": 3,
  "name": "My Premium Extension",
  "version": "1.0.0",
  "description": "A Chrome extension with free and premium features powered by Mainlayer.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://api.mainlayer.xyz/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
